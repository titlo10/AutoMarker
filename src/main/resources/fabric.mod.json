{
	"schemaVersion": 1,
	"id": "automarker",
	"version": "${version}",
	"name": "${name}",
	"description": "Automatically adds markers to ReplayMod recordings when trigger events occur.",
	"authors": [
		"Antigravity"
	],
	"contact": {},
	"license": "GPL-3.0-only",
	"icon": "assets/automarker/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.example.ExampleMod"
		],
		"client": [
			"com.example.client.ExampleModClient"
		],
		"modmenu": [
			"com.example.client.ModMenuIntegration"
		]
	},
	"mixins": [
		{
			"config": "automarker.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.0",
		"minecraft": ">=1.21",
		"java": ">=21",
		"fabric-api": "*",
		"replaymod": "*"
	}
}